# @project/rag reads these from the HOST process env (dashboard / discord bot).
# Bun auto-loads each app's own .env — this file is just documentation.

GEMINI_API_KEY=

# Models (override freely; these are the project defaults)
GEMINI_CHAT_MODEL=gemini-flash-latest
GEMINI_EMBED_MODEL=gemini-embedding-2
GEMINI_EMBED_DIM=768

# Chunking / retrieval
RAG_CHUNK_TOKENS=800
RAG_CHUNK_OVERLAP_TOKENS=120
RAG_TOP_K=6

# Rung-1: inject the whole corpus when its token estimate is <= this value,
# otherwise fall back to RAG top-k. Chat model window is ~1M tokens.
RAG_FULL_CONTEXT_TOKEN_THRESHOLD=800000

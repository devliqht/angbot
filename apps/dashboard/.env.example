# Dashboard (Next.js) environment. Copy to .env and fill in.

# Database — the same MySQL instance as packages/database
DATABASE_URL="mysql://user:password@localhost:3306/angbot"

# Auth.js — generate a secret with: bunx auth secret  (or: openssl rand -base64 33)
AUTH_SECRET=
# Google OAuth client (Google Cloud Console -> Credentials -> OAuth client ID)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Discord OAuth client (Discord Developer Portal -> Applications -> OAuth2 -> General)
# # FOR DISCORD LOGIN ASK MATT
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Discord bot token (same one used by apps/discord) — read-only lookups
# (e.g. resolving a guild's name for the server picker).
DISCORD_TOKEN=

# Public — the BOT's application ID (may differ from AUTH_DISCORD_ID, which is
# a separate Discord app used only for dashboard login). Must match the app
# behind apps/discord's DISCORD_TOKEN. Used client-side for the "Add Server"
# bot-invite link (Discord client/application IDs are not secret).
NEXT_PUBLIC_DISCORD_CLIENT_ID=

# Gemini (consumed by @project/rag)
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-flash-latest
GEMINI_EMBED_MODEL=gemini-embedding-2

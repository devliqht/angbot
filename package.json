{
	"name": "angbot",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev:dashboard": "bun --filter dashboard dev",
		"dev:bot": "bun run --cwd apps/discord dev",
		"db:migrate": "bun run --bun --cwd packages/database prisma migrate dev",
		"db:studio": "bun run --bun --cwd packages/database prisma studio",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@types/bun": "latest",
		"lefthook": "^2.1.9",
		"typescript": "^5"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"overrides": {
		"postcss": "8.5.15"
	}
}
